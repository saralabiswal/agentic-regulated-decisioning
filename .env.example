# Runtime mode: mock | real | local_sync
APP_MODE=local_sync

# Redis Streams endpoint for asynchronous eventing
REDIS_URL=redis://localhost:6379

# PostgreSQL database for audit, workbench, DLQ, and analytics
POSTGRES_PORT=15432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/regulated_decisioning

# MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5001

# OpenTelemetry OTLP endpoint used by Jaeger
JAEGER_ENDPOINT=http://localhost:4317

# LLM provider: auto | mock | ollama | openai | anthropic | any LiteLLM provider name
LLM_PROVIDER=ollama
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=2

# Ollama endpoint for local inference
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Cloud provider API keys; never returned by the config API
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Default demo settings
DEFAULT_DOMAIN=insurance
DEFAULT_JURISDICTION=US_CA

# CORS origins for production, comma-separated. Empty means allow all in dev.
CORS_ORIGINS=
